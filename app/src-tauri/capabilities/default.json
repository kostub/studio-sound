{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main Studio Sound App window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "studio-sidecar", "sidecar": true, "args": ["serve"] }
      ]
    },
    {
      "identifier": "shell:allow-stdin-write",
      "allow": [
        { "name": "studio-sidecar", "sidecar": true, "args": ["serve"] }
      ]
    }
  ]
}
