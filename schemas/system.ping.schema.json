{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://studiosound.app/schemas/system.ping.schema.json",
  "title": "SystemPing",
  "type": "object",
  "$defs": {
    "PingPayload": { "type": "null" },
    "PingResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pong", "sidecarVersion", "uptimeMs", "supportedProtocolVersions"],
      "properties": {
        "pong": { "type": "boolean", "const": true },
        "sidecarVersion": { "type": "string", "minLength": 1 },
        "uptimeMs": { "type": "integer", "minimum": 0 },
        "supportedProtocolVersions": {
          "type": "array", "minItems": 1,
          "items": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
